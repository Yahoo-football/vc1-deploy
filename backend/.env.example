NODE_ENV=production
PORT=5000

JWT_SECRET=replace_with_a_long_random_secret_at_least_32_characters
JWT_EXPIRES_IN=7d

DB_HOST=localhost
DB_PORT=3306
DB_NAME=football_booking
DB_USER=football_app
DB_PASSWORD=replace_with_database_password
DB_SSL=false
DB_LOGGING=false

CORS_ORIGIN=https://roeurn.rest,https://www.roeurn.rest,http://localhost:3000,http://127.0.0.1:3000
CORS_VERCEL_PREVIEW_SUFFIXES=.vercel.app
RATE_LIMITING=true
HTTP_LOGGING=true
LOG_LEVEL=info
APP_TIMEZONE=Asia/Bangkok

MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/gif,image/webp,image/avif,image/svg+xml
ALLOWED_FILE_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.avif,.svg

DB_SYNC_ALTER=false
DB_SYNC_IN_PRODUCTION=false

FOOTBALL_API_KEY=optional_football_data_org_api_key
